{
  "name": "cursor-proxy",
  "displayName": "Cursor Proxy",
  "publisher": "funny-vibes",
  "description": "Unified AI Agent Gateway — Route Antigravity, Claude, and GPT backends through Cursor IDE and Claude Code CLI with protocol-native translation.",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "homepage": "https://github.com/funny-vibes/cursor-proxy#readme",
  "bugs": {
    "url": "https://github.com/funny-vibes/cursor-proxy/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/funny-vibes/cursor-proxy.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI"
  ],
  "keywords": [
    "agent",
    "cursor",
    "codex",
    "claude",
    "chatgpt",
    "antigravity",
    "vibe-coding",
    "vibecoding",
    "gemini",
    "llm"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://github.com/funny-vibes/cursor-proxy/actions/workflows/ci.yml/badge.svg?branch=main",
      "href": "https://github.com/funny-vibes/cursor-proxy/actions/workflows/ci.yml",
      "description": "CI Status"
    },
    {
      "url": "https://img.shields.io/badge/License-MIT-blue.svg",
      "href": "https://github.com/funny-vibes/cursor-proxy/blob/main/LICENSE",
      "description": "MIT License"
    },
    {
      "url": "https://img.shields.io/badge/Node.js-≥24-339933?logo=nodedotjs&logoColor=white",
      "href": "https://nodejs.org/",
      "description": "Node.js ≥ 24"
    }
  ],
  "preview": true,
  "markdown": "github",
  "qna": "https://github.com/funny-vibes/cursor-proxy/discussions",
  "sponsor": {
    "url": "https://github.com/sponsors/funny-vibes"
  },
  "extensionKind": [
    "ui"
  ],
  "icon": "resources/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorProxy.startServer",
        "title": "Start Server",
        "category": "Cursor Proxy",
        "icon": "$(play)"
      },
      {
        "command": "cursorProxy.stopServer",
        "title": "Stop Server",
        "category": "Cursor Proxy",
        "icon": "$(debug-stop)"
      },
      {
        "command": "cursorProxy.restartServer",
        "title": "Restart Server",
        "category": "Cursor Proxy",
        "icon": "$(debug-restart)"
      },
      {
        "command": "cursorProxy.syncAntigravityIDE",
        "title": "Sync Antigravity IDE Credentials",
        "category": "Cursor Proxy"
      },
      {
        "command": "cursorProxy.syncAntigravityTools",
        "title": "Sync Antigravity Tool Credentials",
        "category": "Cursor Proxy"
      },
      {
        "command": "cursorProxy.syncClaude",
        "title": "Sync Claude Credentials",
        "category": "Cursor Proxy"
      },
      {
        "command": "cursorProxy.syncCodex",
        "title": "Sync Codex Credentials",
        "category": "Cursor Proxy"
      },
      {
        "command": "cursorProxy.generateCert",
        "title": "Generate SSL Certificates",
        "category": "Cursor Proxy"
      },
      {
        "command": "cursorProxy.enableForwarding",
        "title": "Enable Port Forwarding",
        "category": "Cursor Proxy"
      },
      {
        "command": "cursorProxy.disableForwarding",
        "title": "Disable Port Forwarding",
        "category": "Cursor Proxy"
      },
      {
        "command": "cursorProxy.forwardingStatus",
        "title": "Port Forwarding Status",
        "category": "Cursor Proxy"
      },
      {
        "command": "cursorProxy.openDashboard",
        "title": "Open Dashboard",
        "category": "Cursor Proxy",
        "icon": "$(dashboard)"
      },
      {
        "command": "cursorProxy.collectDiagnostics",
        "title": "Collect Diagnostics",
        "category": "Cursor Proxy"
      },
      {
        "command": "cursorProxy.openConfig",
        "title": "Edit Configuration",
        "category": "Cursor Proxy",
        "icon": "$(gear)"
      },
      {
        "command": "cursorProxy.patchCursor",
        "title": "Apply Cursor Patch",
        "category": "Cursor Proxy"
      },
      {
        "command": "cursorProxy.restoreCursor",
        "title": "Restore Cursor Original",
        "category": "Cursor Proxy"
      },
      {
        "command": "cursorProxy.refreshDashboard",
        "title": "Refresh Dashboard",
        "category": "Cursor Proxy",
        "icon": "$(refresh)"
      }
    ],
    "configuration": {
      "title": "Cursor Proxy",
      "properties": {
        "cursorProxy.language": {
          "type": "string",
          "default": "en",
          "enum": [
            "en",
            "zh"
          ],
          "enumDescriptions": [
            "English",
            "中文"
          ],
          "description": "Dashboard display language"
        },
        "cursorProxy.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the proxy server when IDE launches"
        },
        "cursorProxy.port": {
          "type": "number",
          "default": 2026,
          "description": "Proxy server port"
        },
        "cursorProxy.healthCheckInterval": {
          "type": "number",
          "default": 30,
          "description": "Health check polling interval in seconds (0 to disable)"
        },
        "cursorProxy.debugMode": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging"
        },
        "cursorProxy.dataDir": {
          "type": "string",
          "default": "",
          "description": "Custom data directory path (default: ~/.cursor-proxy)"
        },
        "cursorProxy.antigravityAccountsPath": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path for antigravity-accounts.json. If empty, uses <dataDir>/data/antigravity-accounts.json"
        },
        "cursorProxy.codexAccountsPath": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path for codex-accounts.json. If empty, uses <dataDir>/data/codex-accounts.json"
        },
        "cursorProxy.openaiCompatAccountsPath": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path for openai-compat-accounts.json. If empty, uses <dataDir>/data/openai-compat-accounts.json"
        },
        "cursorProxy.claudeApiAccountsPath": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path for claude-api-accounts.json. If empty, uses <dataDir>/data/claude-api-accounts.json"
        }
      }
    }
  },
  "scripts": {
    "build": "npm run build:chatgpt-register && node esbuild.config.mjs --production",
    "build:bridge": "node scripts/build-bridge.mjs",
    "build:chatgpt-register": "npm --workspace ../chatgpt-register run build",
    "sync:bridge": "node scripts/sync-bridge-assets.mjs",
    "sync:chatgpt-register": "node scripts/sync-chatgpt-register-assets.mjs",
    "verify:bridge": "node scripts/sync-bridge-assets.mjs --verify-only",
    "restart:bridge": "node scripts/restart-bridge-after-pack.mjs",
    "sync:readme": "node scripts/sync-readme.mjs",
    "prepare:pack": "npm run build && npm run build:bridge && npm run sync:bridge && npm run sync:chatgpt-register && npm run sync:readme",
    "prepare:pack:fast": "npm run build && npm run verify:bridge && npm run sync:chatgpt-register && npm run sync:readme",
    "dev": "node esbuild.config.mjs --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "jest --passWithNoTests",
    "types": "tsc --noEmit",
    "package": "npm run prepare:pack && npx @vscode/vsce package --no-dependencies",
    "package:fast": "npm run prepare:pack:fast && npx @vscode/vsce package --no-dependencies",
    "pack": "npm run package && cursor --install-extension agent-vibes-$npm_package_version.vsix --force && npm run restart:bridge",
    "pack:fast": "npm run package:fast && cursor --install-extension agent-vibes-$npm_package_version.vsix --force && npm run restart:bridge",
    "clean": "node ../../scripts/rm-paths.js dist node_modules .turbo"
  },
  "dependencies": {
    "node-forge": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-forge": "^1.3.11",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6"
  },
  "prettier": "@workspace/prettier-config"
}
